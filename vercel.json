{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "functions": {
    "api/[...all].js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/objects/:path*", "destination": "/api/[...all].js" },
    { "source": "/api/:path*", "destination": "/api/[...all].js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/reservations/cron/expire-no-shows", "schedule": "0 0 * * *" }
  ]
}
