{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "functions": {
    "api/[...all].js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/objects/:path*", "destination": "http://18.142.14.142/objects/:path*" },
    { "source": "/api/upload-photo", "destination": "http://18.142.14.142/api/upload-photo" },
    { "source": "/api/upload-document", "destination": "http://18.142.14.142/api/upload-document" },
    { "source": "/api/objects/:path*", "destination": "http://18.142.14.142/api/objects/:path*" },
    { "source": "/api/:path*", "destination": "/api/[...all].js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/reservations/cron/expire-no-shows", "schedule": "0 * * * *" }
  ]
}
